{
  "name": "mnn-clip-namer",
  "version": "0.1.0",
  "description": "Drag-drop desktop app that auto-names video clips using OpenAI gpt-4o-mini.",
  "main": "dist-electron/main.js",
  "author": "MNN",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.electron.json && vite build && electron-builder",
    "build:mac": "tsc -p tsconfig.electron.json && vite build && electron-builder --mac",
    "build:win": "tsc -p tsconfig.electron.json && vite build && electron-builder --win",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffmpeg-installer/win32-x64": "^4.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@ffprobe-installer/win32-x64": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "keytar": "^7.9.0",
    "p-limit": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.mnn.clipnamer",
    "productName": "MNN Clip Namer",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "fileAssociations": [
      {
        "ext": [
          "mov",
          "mp4",
          "mkv",
          "m4v"
        ],
        "name": "Video Clip",
        "role": "Viewer"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    },
    "portable": {
      "artifactName": "MNN-Clip-Namer-${version}.exe"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@ffprobe-installer/**/*",
      "node_modules/keytar/**/*"
    ]
  }
}
